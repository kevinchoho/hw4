<!DOCTYPE html>
<html>
  <head>
    <title>Tacostagram Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>
  
  <body>
    <nav class="navbar navbar-dark bg-dark">
      <a href="/" class="navbar-brand">Home</a>
    <div>
    <% if @current_user != nil %>
      <span class="text-white">Logged in as: <%= @current_user["username"] %></span>
      <a href="/logout" class="btn btn-outline-light ms-2">Logout</a>
    <% else %>
      <a href="/login" class="btn btn-outline-light">Login</a>
      <a href="/signup" class="btn btn-outline-light ms-2">Signup</a>
    <% end %>
    </div>
    </nav>
     <div class="container">
      <div>
        <%= flash["notice"] %>
      </div>
      <%= yield %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  </body>
</html>

