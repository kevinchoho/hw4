<h1><%= @place["name"] %></h1>

<h2>My Entries</h2>
<div class="row">
  <% @entries.each do |entry| %>
    <div class="col-lg-4 col-md-6 mb-4">
      <div class="card">
        <% if entry.uploaded_image.attached? %>
          <img src="<%= url_for(entry.uploaded_image) %>" class="card-img-top">
        <% end %>
        <div class="card-body">
          <h5 class="card-title"><%= entry["title"] %></h5>
          <p class="card-text"><%= entry["description"] %></p>
          <p class="card-text"><small><%= entry["occurred_on"] %></small></p>
        </div>
      </div>
    </div>
  <% end %>
</div>
<p>
 <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
</p>

<p>
  <a href="/places" class="btn btn-primary">Back to All Places</a>
</p>

