<h1>New Entry</h1>

<form action="/entries" method="post" enctype="multipart/form-data">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <input type="hidden" name="place_id" value="<%= @place_id %>">
  
  <div class="mb-3">
    <label class="form-label">Title</label>
    <input type="text" name="title" class="form-control">
  </div>

  <div class="mb-3">
    <label class="form-label">Description</label>
    <textarea name="description" class="form-control" rows="4"></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Occurred On</label>
    <input type="date" name="occurred_on" class="form-control">
  </div>

  <div class="mb-3">
    <label class="form-label">Upload Image (Optional)</label>
    <input type="file" name="uploaded_image" class="form-control" accept="image/png, image/jpg, image/jpeg, image/gif">
  </div>

  <button type="submit" class="btn btn-primary">Save Entry</button>
  <a href="/places/<%= @place_id %>" class="btn btn-secondary">Cancel</a>
</form>
